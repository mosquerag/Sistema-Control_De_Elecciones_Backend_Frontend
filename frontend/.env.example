# ═══════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO - FRONTEND
# ═══════════════════════════════════════════════════════════════════════
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env
# 2. Completar los valores reales
# 3. NO subir .env a Git (ya está en .gitignore)

# ═══════════════════════════════════════════════════════════════════════
# API BACKEND
# ═══════════════════════════════════════════════════════════════════════

# URL del backend
VITE_API_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH
# ═══════════════════════════════════════════════════════════════════════

# Google Client ID
# Obtener en: https://console.cloud.google.com/apis/credentials
# Formato: xxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ═══════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE DESARROLLO (OPCIONAL)
# ═══════════════════════════════════════════════════════════════════════

# Puerto del servidor de desarrollo (por defecto: 5173)
# VITE_PORT=5173

# Modo de desarrollo
# VITE_MODE=development