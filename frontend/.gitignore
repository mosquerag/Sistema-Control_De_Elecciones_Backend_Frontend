# ═══════════════════════════════════════════════════════════════════════
# ARCHIVO: .gitignore
# UBICACIÓN: /frontend/.gitignore
# DESCRIPCIÓN: Archivos y carpetas que NO deben subirse a Git
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════
# ARCHIVOS DE ENTORNO Y CONFIGURACIÓN SENSIBLE
# ═══════════════════════════════════════════════════════════════════════

# Variables de entorno (NUNCA subir)
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# ═══════════════════════════════════════════════════════════════════════
# DEPENDENCIAS
# ═══════════════════════════════════════════════════════════════════════

# Dependencias de npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ═══════════════════════════════════════════════════════════════════════
# BUILD Y DIST
# ═══════════════════════════════════════════════════════════════════════

# Archivos de build
dist/
dist-ssr/
build/
*.local

# ═══════════════════════════════════════════════════════════════════════
# EDITORES E IDEs
# ═══════════════════════════════════════════════════════════════════════

# VSCode
.vscode/
.vscode/*
!.vscode/extensions.json
*.code-workspace

# WebStorm
.idea/
*.iml

# Sublime
*.sublime-project
*.sublime-workspace

# ═══════════════════════════════════════════════════════════════════════
# SISTEMA OPERATIVO
# ═══════════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

# ═══════════════════════════════════════════════════════════════════════
# TESTING Y COVERAGE
# ═══════════════════════════════════════════════════════════════════════

coverage/
*.lcov
.nyc_output/

# ═══════════════════════════════════════════════════════════════════════
# LOGS
# ═══════════════════════════════════════════════════════════════════════

logs/
*.log

# ═══════════════════════════════════════════════════════════════════════
# TEMPORAL
# ═══════════════════════════════════════════════════════════════════════

tmp/
temp/
*.tmp
*.swp
*.swo