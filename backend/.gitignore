# ═══════════════════════════════════════════════════════════════════════
# ARCHIVO: .gitignore
# UBICACIÓN: /backend/.gitignore
# DESCRIPCIÓN: Archivos y carpetas que NO deben subirse a Git
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════
# ARCHIVOS DE ENTORNO Y CONFIGURACIÓN SENSIBLE
# ═══════════════════════════════════════════════════════════════════════

# Variables de entorno (NUNCA subir al repositorio)
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Configuraciones locales
config/local.js
config/*.local.js

# Claves y certificados
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx

# Credenciales de Google Cloud
google-credentials.json
gcloud-service-key.json

# ═══════════════════════════════════════════════════════════════════════
# NODE_MODULES Y DEPENDENCIAS
# ═══════════════════════════════════════════════════════════════════════

# Dependencias de npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Archivos de bloqueo opcionales (descomentar si quieres ignorarlos)
# package-lock.json
# yarn.lock

# ═══════════════════════════════════════════════════════════════════════
# LOGS Y DATOS TEMPORALES
# ═══════════════════════════════════════════════════════════════════════

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Archivos de runtime
pids/
*.pid
*.seed
*.pid.lock

# Cobertura de tests
coverage/
*.lcov
.nyc_output/

# ═══════════════════════════════════════════════════════════════════════
# BASES DE DATOS LOCALES
# ═══════════════════════════════════════════════════════════════════════

# MongoDB local
data/
*.db
*.sqlite
*.sqlite3

# Dumps de base de datos
*.dump
*.sql
*.bak

# ═══════════════════════════════════════════════════════════════════════
# ARCHIVOS DE SISTEMA OPERATIVO
# ═══════════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ═══════════════════════════════════════════════════════════════════════
# EDITORES E IDEs
# ═══════════════════════════════════════════════════════════════════════

# VSCode
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

